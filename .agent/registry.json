  "taskTypeModuleListsNote": "The 'research' task type intentionally mixes the literal module paths given in the original AOS specification (research-policy.md, source-ranking.md, knowledge-ingestion.md under research/; evidence.md under quality/) with manifest module IDs used elsewhere. scripts/validate-aos-manifest.mjs resolves both a bare '<category>/<file>.md' path and a manifest module ID against manifest.json, so either form is valid; a path with no matching manifest entry is reported as an orphan task mapping, not silently ignored.",
  "riskLevelDefaults": {
    "Low": ["documentation", "UI copy update"],
    "Medium": ["feature", "bugfix", "refactor", "testing", "prompt creation", "workflow creation"],
    "High": ["authentication", "data migration", "AI integration", "external provider integration", "synchronization"],
    "Critical": ["coverage threshold change", "MCP tool with write capability", "secret exposure risk", "force push or history rewrite"]
