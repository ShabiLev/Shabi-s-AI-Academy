{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shabis-academy.dev/aos/v1/workflow-candidate.schema.json",
  "title": "Workflow Candidate",
  "description": "A generated workflow template candidate produced by the knowledge-ingestion pipeline, feeding the 'workflow creation' task type (see .agent/research/knowledge-ingestion.md, .agent/templates/workflow.md).",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "sourceIds": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "reviewStatus": {
      "type": "string",
      "enum": [
        "discovered",
        "extracted",
        "verified",
        "translated",
        "pendingReview",
        "approved",
        "published",
        "warning",
        "stale",
        "deprecated",
        "rejected"
      ]
    },
    "freshnessStatus": {
      "type": "string",
      "enum": ["current", "aging", "stale", "deprecated", "superseded", "historical"]
    },
    "translationStatus": {
      "type": "string",
      "enum": ["notStarted", "inProgress", "complete"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "generatedBy": {
      "type": "object",
      "properties": {
        "agent": { "type": "string" },
        "generatedDate": { "type": "string", "format": "date" }
      },
      "required": ["agent", "generatedDate"],
      "additionalProperties": false
    },
    "version": {
      "type": "string"
    },
    "createdDate": {
      "type": "string",
      "format": "date"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "description": { "type": "string" }
        },
        "required": ["order", "description"],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "triggerTaskType": {
      "type": "string",
      "description": "The .agent/registry.json task type this workflow is intended to support, if any."
    }
  },
  "required": [
    "id",
    "title",
    "summary",
    "sourceIds",
    "reviewStatus",
    "freshnessStatus",
    "confidence",
    "generatedBy",
    "version",
    "createdDate",
    "steps"
  ],
  "additionalProperties": false
}
