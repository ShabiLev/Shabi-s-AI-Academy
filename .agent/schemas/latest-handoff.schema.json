{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shabilev.github.io/aos/latest-handoff.schema.json",
  "title": "Latest Handoff",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "sourceBranch",
    "currentBranch",
    "targetBranch",
    "testedCommit",
    "fromAgent",
    "toAgent",
    "status",
    "summary",
    "evidencePath",
    "nextAction"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "generatedAt": { "type": "string" },
    "sourceBranch": { "type": "string", "minLength": 1 },
    "currentBranch": { "type": "string", "minLength": 1 },
    "targetBranch": { "type": "string", "minLength": 1 },
    "testedCommit": { "type": "string", "minLength": 1 },
    "fromAgent": { "type": "string" },
    "toAgent": { "type": "string" },
    "status": { "type": "string" },
    "summary": { "type": "string" },
    "evidencePath": { "type": "string" },
    "nextAction": { "type": "string" }
  }
}
