{
  "name": "shabis-ai-academy",
  "private": true,
  "version": "1.3.0-beta.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "cross-env VITE_BASE_PATH=/Shabi-s-AI-Academy/ VITE_ROUTER_MODE=hash VITE_DEPLOYMENT_PROVIDER=github-pages VITE_PUBLIC_SITE_URL=https://shabilev.github.io/Shabi-s-AI-Academy npm run build && node scripts/validate-pages-build.mjs",
    "preview": "vite preview",
    "preview:pages": "cross-env VITE_BASE_PATH=/Shabi-s-AI-Academy/ VITE_ROUTER_MODE=hash VITE_DEPLOYMENT_PROVIDER=github-pages VITE_PUBLIC_SITE_URL=https://shabilev.github.io/Shabi-s-AI-Academy vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:open": "vitest run --coverage && node -e \"const {execSync}=require('node:child_process');execSync(process.platform==='win32'?'start coverage/index.html':'open coverage/index.html',{shell:true})\"",
    "test:e2e": "cross-env PW_REPORT_NAME=fast playwright test --project=\"Desktop Chromium\"",
    "test:e2e:full": "cross-env PW_FULL=1 PW_REPORT_NAME=full playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --project=\"Desktop Chromium\" --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:pages": "playwright test --config=playwright.pages.config.ts",
    "test:a11y": "cross-env PW_REPORT_NAME=a11y playwright test --project=\"Accessibility\"",
    "test:visual": "cross-env PW_REPORT_NAME=visual playwright test --project=\"visual-chromium\"",
    "test:visual:review": "node quality/scripts/generate-quality-artifacts.mjs",
    "test:visual:update": "node quality/scripts/require-visual-update.mjs && playwright test --project=\"visual-chromium\" --update-snapshots",
    "test:visual:report": "playwright show-report",
    "test:performance": "npm run build && node quality/scripts/run-lighthouse.mjs collect && node quality/scripts/run-lighthouse.mjs assert",
    "test:performance:collect": "npm run build && node quality/scripts/run-lighthouse.mjs collect",
    "test:performance:assert": "node quality/scripts/run-lighthouse.mjs assert",
    "test:performance:open": "node -e \"const {execSync}=require('node:child_process');execSync(process.platform==='win32'?'start quality/generated/lighthouse/login-desktop/index.html':'open quality/generated/lighthouse/login-desktop/index.html',{shell:true})\"",
    "quality:collect": "node quality/scripts/write-build-metadata.mjs && node quality/scripts/collect-quality-results.mjs",
    "quality:analyze": "node quality/scripts/analyze-quality-results.mjs",
    "quality:inventory": "node quality/scripts/validate-inventory.mjs",
    "quality:system-report": "node quality/scripts/generate-quality-artifacts.mjs && node quality/scripts/generate-system-quality-report.mjs",
    "quality:report": "npm run quality:collect && npm run quality:analyze && npm run quality:system-report",
    "test:journeys": "playwright test --config=playwright.journeys.config.ts",
    "test:journeys:headed": "playwright test --config=playwright.journeys.config.ts --headed",
    "test:ui:headed": "cross-env PW_REPORT_NAME=headed playwright test --project=\"Desktop Chromium\" --headed",
    "test:ux": "playwright test --config=playwright.ux.config.ts",
    "test:ux:headed": "playwright test --config=playwright.ux.config.ts --headed",
    "test:click-audit": "playwright test e2e/specs/system-click-audit.spec.ts --project=\"Desktop Chromium\"",
    "test:route-crawl": "playwright test e2e/specs/route-crawler.spec.ts --project=\"Desktop Chromium\"",
    "test:forms": "playwright test e2e/specs/forms-quality.spec.ts --project=\"Desktop Chromium\"",
    "test:overlays": "playwright test e2e/specs/overlays-quality.spec.ts --project=\"Desktop Chromium\"",
    "test:responsive:interactions": "playwright test e2e/specs/responsive-interactions.spec.ts --project=\"Desktop Chromium\"",
    "test:keyboard": "playwright test e2e/specs/keyboard-journeys.spec.ts --project=\"Desktop Chromium\"",
    "test:copy": "playwright test e2e/specs/copy-quality.spec.ts --project=\"Desktop Chromium\"",
    "test:errors": "playwright test e2e/specs/error-recovery.spec.ts --project=\"Desktop Chromium\"",
    "test:release-candidate": "npm run build && npm run quality:inventory && npm run test:journeys && npm run test:ux && npm run test:a11y && npm run test:visual && npm run quality:system-report",
    "test:release-candidate:pages": "npm run build:pages && npm run quality:inventory && npm run test:e2e:pages && npm run quality:system-report",
    "catalog:check": "node scripts/check-prompt-catalog.mjs",
    "catalog:update": "node scripts/update-prompt-catalog.mjs",
    "catalog:report": "node scripts/report-prompt-catalog.mjs",
    "docs:check": "node scripts/check-codex-docs.mjs",
    "validate": "npm run lint && npm run test:run && npm run build && npm run test:e2e",
    "validate:full": "npm run lint && npm run test:run && npm run build && npm run test:e2e:full",
    "validate:quality": "npm run lint && npm run test:run && npm run test:coverage && npm run build && npm run test:e2e && npm run test:a11y",
    "validate:release": "npm run lint && npm run test:run && npm run test:coverage && npm run build && npm run catalog:check && npm run docs:check && npm run quality:inventory && npm run test:e2e:full && npm run test:journeys && npm run test:ux && npm run test:a11y && npm run test:visual && npm run test:performance && npm run quality:collect && npm run quality:analyze && npm run quality:system-report && npm run test:e2e:pages && git diff --check"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@tailwindcss/vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "tailwindcss": "latest"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.25.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.7",
    "cross-env": "^10.1.0",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "jsdom": "^26.1.0",
    "puppeteer": "^24.43.1",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
