{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shabilev.github.io/aos/current-task.schema.json",
  "title": "Current Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "sourceBranch",
    "currentBranch",
    "targetBranch",
    "testedCommit",
    "task",
    "startingCommit",
    "objective",
    "completedWork",
    "workInProgress",
    "blockedWork",
    "filesBeingChanged",
    "testsRun",
    "testsStillRequired",
    "manualReviewsRequired",
    "evidencePath",
    "nextAction"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "generatedAt": { "type": "string" },
    "sourceBranch": { "type": "string", "minLength": 1 },
    "currentBranch": { "type": "string", "minLength": 1 },
    "targetBranch": { "type": "string", "minLength": 1 },
    "testedCommit": { "type": "string", "minLength": 1 },
    "task": { "type": "string", "minLength": 1 },
    "startingCommit": { "type": "string" },
    "objective": { "type": "string" },
    "completedWork": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 100
    },
    "workInProgress": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 100
    },
    "blockedWork": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 50
    },
    "filesBeingChanged": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 120
    },
    "testsRun": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 100
    },
    "testsStillRequired": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 100
    },
    "manualReviewsRequired": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 20
    },
    "evidencePath": { "type": ["string", "null"] },
    "nextAction": { "type": "string" }
  }
}
