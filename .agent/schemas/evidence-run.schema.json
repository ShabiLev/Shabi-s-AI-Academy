{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shabis-academy.dev/aos/v1/evidence-run.schema.json",
  "title": "Evidence Run",
  "type": "object",
  "required": ["identity", "commands", "overallStatus"],
  "properties": {
    "identity": {
      "type": "object",
      "required": ["runId", "sourceBranch", "runtimeBranch", "targetBranch", "executionContext", "testedCommit", "evidenceCommit", "generatedAt", "workingTreeCleanAtTest"],
      "properties": {
        "runId": {"type":"string"},
        "sourceBranch": {"type":"string"},
        "runtimeBranch": {"type":"string"},
        "targetBranch": {"type":"string"},
        "executionContext": {"enum":["localFeature","localMain","githubPush","githubPullRequest","githubMergeRef","detachedHead","unknown"]},
        "testedCommit": {"type":"string"},
        "evidenceCommit": {"type":"string"},
        "parentCommit": {"type":["string","null"]},
        "generatedAt": {"type":"string"},
        "workingTreeCleanAtTest": {"type":"boolean"},
        "integrityValidation": {"type":"string"}
      },
      "additionalProperties": true
    },
    "commands": {"type":"array"},
    "overallStatus": {"enum":["passed","failed","partial","notAvailable"]}
  },
  "additionalProperties": true
}
